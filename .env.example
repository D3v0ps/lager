NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Public site URL used to build magic-link / password-reset redirect URLs
# server-side. Falls back to window.location.origin in the browser, but set
# this in production so SSR builds don't accidentally send relative redirects.
NEXT_PUBLIC_SITE_URL=https://portal.example.se
